# API Configuration
VITE_API_URL=http://localhost:5005
VITE_API_TIMEOUT=30000

# Network is set by startClient.sh (VITE_NETWORK=base or base-sepolia)
# Do NOT set VITE_NETWORK here — it comes from the start script

# Contract Addresses (required — app will not start without these)
VITE_BOUNTY_ESCROW_ADDRESS_BASE_SEPOLIA=
VITE_BOUNTY_ESCROW_ADDRESS_BASE=
VITE_LINK_TOKEN_ADDRESS_BASE_SEPOLIA=
VITE_LINK_TOKEN_ADDRESS_BASE=
VITE_VERDIKTA_AGGREGATOR_ADDRESS_BASE_SEPOLIA=
VITE_VERDIKTA_AGGREGATOR_ADDRESS_BASE=

# IPFS Gateway (for read-only fetching)
VITE_IPFS_GATEWAY=https://ipfs.io

# Feature Flags
VITE_ENABLE_DEBUG=false

# Client identification (must match FRONTEND_CLIENT_KEY in server/.env)
# Generate a secure key and use same value in both client and server
VITE_CLIENT_KEY=your-frontend-secret-key-here
