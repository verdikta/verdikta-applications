# .env
# Secret info should be placed outside the repository in ../../../secrets/.env.secrets
HARDHAT_NETWORK=base_sepolia

# ETH-funded ReputationAggregator (LINK rail retired)
VERDIKTA_AGGREGATOR_BASE_SEPOLIA=0xe8a385E473EA710c5a88Cc72681a16a26fe380e4
VERDIKTA_AGGREGATOR_BASE=0xd8F38bCBEE43bE3bd31655a563f20c9B3e67142a

# Network configuration
# SECRETS DO NOT BELONG HERE. Put PRIVATE_KEY / PRIVATE_KEY_2 / INFURA_API_KEY /
# ETHERSCAN_API_KEY / BASESCAN_API_KEY only in .env.secrets.
# NOTE: deploy*.sh does `source .env`, which would export any PRIVATE_KEY set here
# and OVERRIDE the one in .env.secrets (dotenv does not override already-set vars).
# So leaving a key here silently changes which account deploys. Keep these unset.
# PRIVATE_KEY=          (set in .env.secrets, NOT here)
# PRIVATE_KEY_2=        (set in .env.secrets, NOT here)
# INFURA_API_KEY="66..."
# ETHERSCAN_API_KEY=4Y...
# BASESCAN_API_KEY=7V...


# Verdikta
WRAPPED_VERDIKTA_TOKEN_BASE_SEPOLIA=0x94e3c031fe9403c80E14DaFbCb73f191C683c2B1
WRAPPED_VERDIKTA_TOKEN_BASE=0x1EA68D018a11236E07D5647175DAA8ca1C3D0280


