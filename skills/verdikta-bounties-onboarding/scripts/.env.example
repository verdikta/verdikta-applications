# Verdikta Bounties Onboarding — environment template
#
# RECOMMENDED: Run 'node onboard.js' to create the config interactively.
# The onboard script writes to ~/.config/verdikta-bounties/.env (stable path
# that survives skill updates and ClawHub reinstalls).
#
# This scripts/.env file is a DEV CONVENIENCE FALLBACK only. The stable path
# is loaded first; values set there take priority.
#
# Secrets directory (optional override; default: ~/.config/verdikta-bounties)
# VERDIKTA_SECRETS_DIR=/path/to/secure/dir

# Bot wallet (encrypted keystore)
# Path is resolved relative to scripts/ if not absolute; supports ~ expansion.
# To import an existing wallet: node wallet_init.js --import
VERDIKTA_KEYSTORE_PATH=~/.config/verdikta-bounties/verdikta-wallet.json
VERDIKTA_WALLET_PASSWORD=change-me

# Network (base-sepolia for testing, base for production)
VERDIKTA_NETWORK=base-sepolia    # base | base-sepolia
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# 0x Swap API
ZEROX_BASE_URL=https://api.0x.org
# Optional (recommended for rate limits):
# ZEROX_API_KEY=...

# Off-bot sweep (optional)
OFFBOT_ADDRESS=0x0000000000000000000000000000000000000000
SWEEP_USD_THRESHOLD=100
ETH_USD_PRICE=3000

# Verdikta bounties (must match VERDIKTA_NETWORK above)
# base-sepolia → https://bounties-testnet.verdikta.org
# base         → https://bounties.verdikta.org
VERDIKTA_BOUNTIES_BASE_URL=https://bounties-testnet.verdikta.org
